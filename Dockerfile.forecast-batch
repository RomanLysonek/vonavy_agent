FROM python:3.12.3-slim-bookworm AS build

ARG UV_VERSION=0.10.0
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never \
    UV_PROJECT_ENVIRONMENT=/opt/venv

RUN python -m pip install "uv==${UV_VERSION}"
WORKDIR /build
COPY pyproject.toml uv.lock README.md ./

# Keep dependency and immutable model layers independent of application-source
# changes. A source-only worker update must not re-download Chronos-2.
RUN uv sync --frozen --no-dev --no-install-project --extra aws --extra modeling --extra chronos --python /usr/local/bin/python

RUN set -eu; \
    attempt=1; \
    while true; do \
        if /opt/venv/bin/python -c "from huggingface_hub import snapshot_download; snapshot_download(repo_id='amazon/chronos-2', revision='29ec3766d36d6f73f0696f85560a422f50e8498c', local_dir='/opt/models/chronos-2', allow_patterns=['*.json', '*.safetensors', '*.model', '*.txt'])"; then \
            break; \
        fi; \
        if [ "$attempt" -ge 6 ]; then \
            echo "Chronos-2 snapshot download failed after ${attempt} attempts" >&2; \
            exit 1; \
        fi; \
        delay=$((attempt * 10)); \
        echo "Chronos-2 snapshot download failed; retrying in ${delay}s (attempt ${attempt}/6)" >&2; \
        sleep "$delay"; \
        attempt=$((attempt + 1)); \
    done

COPY src ./src
RUN uv sync --frozen --no-dev --no-editable --extra aws --extra modeling --extra chronos --python /usr/local/bin/python

FROM python:3.12.3-slim-bookworm AS runtime

ARG VCS_REF=unknown
LABEL org.opencontainers.image.title="Vonavy Agent forecast worker" \
      org.opencontainers.image.description="AWS Batch adapters for XGBoost, NeuralNet, and Chronos-2 forecasting" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.source="https://github.com/RomanLysonek/vonavy_agent"

ENV PATH="/opt/venv/bin:${PATH}" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOME=/home/worker \
    OMP_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    NUMEXPR_NUM_THREADS=1 \
    CHRONOS2_MODEL_PATH=/opt/models/chronos-2 \
    HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    TOKENIZERS_PARALLELISM=false

RUN groupadd --gid 10001 worker \
    && useradd --uid 10001 --gid 10001 --create-home --shell /usr/sbin/nologin worker

COPY --from=build --chown=10001:10001 /opt/venv /opt/venv
COPY --from=build --chown=10001:10001 /opt/models /opt/models
WORKDIR /home/worker
USER 10001:10001
ENTRYPOINT ["python", "-m", "vonavy_agent.forecasting.aws_batch"]
